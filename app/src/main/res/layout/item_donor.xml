<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="7dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="11dp"
        android:gravity="center_vertical">

        <!-- BLOOD GROUP CIRCLE -->
        <TextView
            android:id="@+id/tvBloodGroup"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_bg"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <!-- DONOR INFO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="11dp">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

            <TextView
                android:id="@+id/tvCityAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#757575"
                android:layout_marginTop="1dp"/>

            <!-- FIX 1: removed android:gap="4dp" — dot gets marginEnd instead -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <View
                    android:id="@+id/availDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/dot_green"/>

                <TextView
                    android:id="@+id/tvAvailability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>

            </LinearLayout>
        </LinearLayout>

        <!-- ACTION BUTTONS -->
        <!-- FIX 2: removed android:gap="5dp" — call button gets marginBottom instead -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnCall"
                android:layout_width="33dp"
                android:layout_height="33dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/circle_red_light"
                android:src="@drawable/ic_call"
                android:contentDescription="Call"/>

            <ImageButton
                android:id="@+id/btnWhatsapp"
                android:layout_width="33dp"
                android:layout_height="33dp"
                android:background="@drawable/circle_green_light"
                android:src="@drawable/ic_whatsapp"
                android:contentDescription="WhatsApp"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>